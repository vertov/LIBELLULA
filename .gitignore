# ==========================================================================
# LIBELLULA Core v22 — .gitignore
# ==========================================================================

# ---- Build outputs (regenerated by the Makefile; never commit) ----
sim/build/
sim/build_all/
build/

# ---- Simulator / waveform artefacts ----
*.vcd
*.fst
*.ghw
*.wdb
*.wlf
*.vvp
*.vpp

# Per-bench iverilog logs live in sim/build/ (already ignored via sim/build/),
# but guard against stray ones.
*_iverilog.log

# ---- Python tooling (coverage_report.py, req_trace.py) ----
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- IDE / editor metadata ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- macOS metadata ----
.DS_Store
._*
.Spotlight-V100
.Trashes
.fseventsd
Icon
Icon?

# ---- Windows metadata ----
Thumbs.db
Desktop.ini

# ---- Local tooling / agent settings (user-specific) ----
.claude/

# ---- Common temp / log patterns ----
*.tmp
*.bak
*.orig
*.rej
